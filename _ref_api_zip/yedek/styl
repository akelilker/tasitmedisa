/* Görüntü modunda 'select' (Tramer) kutusunun okunu gizle */
#vehicle-detail-view.view-mode #vehicle-detail-tramer-input {
    -webkit-appearance: none;
    appearance: none;
    pointer-events: none; /* Tıklanmasını da engelle */
}
/* Görüntü modunda tüm giriş alanlarına tıklamayı engelle */
