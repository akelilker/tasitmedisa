  .settings-dropdown {
     background: rgba(45, 45, 45, 0.6);
     border: 1px solid #999;
     backdrop-filter: blur(10px);
     -webkit-backdrop-filter: blur(10px);
  }

  .settings-dropdown button {
    background: none;
