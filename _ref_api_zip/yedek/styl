} /* @media (max-width: 640px) sonu */

@media (min-width: 641px) {
  .wrap {
    max-width: 550px;
  }
  .modal .m-wrap {
    max-width: 550px;
  }
  .stats.stats-5col {
      grid-template-columns: repeat(5, 1fr);
      gap: 8px;
  }
   .stats.stats-5col .stat:last-child {
      grid-column: auto;
   }

    /* Alış Fiyatı ve Toplam Kontrol Hizalaması (MASAÜSTÜ) */
    #purchase-amount-row-wrap {
        display: none;
        grid-template-columns: 1fr 130px 40px;
        gap: 10px;
        align-items: flex-end;
        margin-bottom: 12px;
    }

    #purchase-amount-wrap {
        grid-column: 1 / span 1;
        margin-bottom: 0 !important;
    }

    .joint-total-check {
        grid-column: 2 / span 1;
        align-self: flex-end;
        text-align: right;
        font-size: 12px;
        color: var(--danger-red);
        padding: 0;
        margin: 0;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }
    .joint-total-check[style*="color: var(--green)"] {
        color: var(--green) !important;
    }

    #joint-purchase-wrap {
        grid-column: 1 / span 3;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

  /* MASAÜSTÜ ORTAKLI ALIM */
