/* ====================================================================
   FİNANSAL DURUM - KASA/BANKA TABLOSU MASAÜSTÜ HİZALAMA (v2)
   ==================================================================== */
@media (min-width: 641px) {
    /* Sadece Finansal Durum modalındaki Kasa tablosunu hedefle */
    #modal-fin #cash-transactions-table table {
        table-layout: fixed !important; /* Sütun genişliklerini zorla */
        width: 100%;
    }

    #modal-fin #cash-transactions-table th,
    #modal-fin #cash-transactions-table td {
        text-align: left; /* Global 'center' hizalamasını sıfırla */
        vertical-align: top; /* İçerik taşarsa diye dikey hizalama */
        padding-top: 8px;
        padding-bottom: 8px;
    }

    /* 1. Sütun (Tarih) */
    #modal-fin #cash-transactions-table th:nth-child(1),
    #modal-fin #cash-transactions-table td:nth-child(1) {
        width: 90px; /* Sabit genişlik */
        white-space: nowrap; /* Asla alt satıra inme */
    }

    /* 2. Sütun (Hesap) */
    #modal-fin #cash-transactions-table th:nth-child(2),
    #modal-fin #cash-transactions-table td:nth-child(2) {
        width: 70px; /* Sabit genişlik */
        white-space: nowrap;
    }

    /* 4. Sütun (Tutar) - (last-child daha güvenli) */
    #modal-fin #cash-transactions-table th:last-child,
    #modal-fin #cash-transactions-table td:last-child {
        width: 120px; /* Sabit genişlik */
        white-space: nowrap;
        text-align: right; /* Tutar sağa hizalı kalsın */
        padding-right: 8px;
    }

    /* 3. Sütun (Açıklama) */
    #modal-fin #cash-transactions-table th:nth-child(3),
    #modal-fin #cash-transactions-table td:nth-child(3) {
        /* DÜZELTME: width: 100% kaldırıldı.
           table-layout: fixed olduğu için zaten kalan alanı alacaktır. */
        text-align: left;
        word-break: break-word; /* Kelimeleri kır */

        /* İsteğin (Maksimum 2 satır, fazlası '...') */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.4em; /* Satır yüksekliği */
        max-height: 2.8em; /* 2 satır (2 * 1.4em) */
    }
}

/* ====================================================================
   ARAÇ DETAY MODALI - YENİ TASARIM CSS (v2 - Stil Düzenlemeleri)
   ==================================================================== */
#vehicle-detail-view {
    animation: slideUp 0.3s ease-out;
    padding: 0 0 0 0 !important;
    display: flex;
    flex-direction: column;
    padding-bottom: 8px !important;
}

/* DÜZELTME: Butonları dibe itmek için EKLENDİ */
#vehicle-detail-view > div {
    display: flex;
    flex-direction: column;
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Plaka Boyutu Küçültme */
#vehicle-detail-plate {
    font-size: 22px !important;
    margin-bottom: 0 !important;
    color: var(--theme-color);
    font-weight: 700;
}
#vehicle-detail-brand-model {
     font-size: 22px !important;
}


/* Sol ve Sağ Sütun İç Boşlukları ve Font Boyutları */
#vehicle-detail-view .modal-content-grid > div > div { /* Sol/Sağ sütun içindeki direkt div'ler */
   gap: 12px !important; /* Dikey boşluk */
}

/* Sol Sütun Elemanları */
#vehicle-detail-view div[style*="grid-template-columns: 1fr 1fr"] > div:first-child > div {
    gap: 12px !important; /* Dikey boşluk */
}

#vehicle-detail-view div[style*="font-size: 13px"] { /* Tüm etiketler */
    font-size: 15px !important;
    margin-bottom: 2px !important;
}
#vehicle-detail-view div[style*="font-size: 16px"] { /* Tüm değerler */
    font-size: 15px !important;
}
#vehicle-detail-view div[style*="font-size: 14px"] { /* Boyalı parçalar ve sağdaki başlıklar */
    font-size: 15px !important;
}
#vehicle-detail-painted-parts > div { /* Boyalı parça listesi item */
     font-size: 15px !important;
}

/* Tarih Alanları Hover Efekti */
.vehicle-detail-hover-trigger {
    transition: background-color 0.2s ease;
}
.vehicle-detail-hover-trigger:hover {
    background-color: rgba(255, 255, 255, 0.08) !important;
}

/* Sağ Sütun - Galeride mi Butonları ve Hizalama */
#garage-status-container {
    display: flex !important;
    align-items: center !important; /* Dikey hizalama */
    gap: 15px !important; /* Başlık ve butonlar arası boşluk */
    flex-wrap: wrap; /* Mobil için taşma durumunda alta atsın */
}
#garage-status-container > div:first-child { /* Başlık ("Taşıt Galeride mi?") */
    margin-bottom: 0 !important; /* Alt boşluğu kaldır */
    flex-shrink: 0; /* Küçülmesin */
    padding: 0 !important; /* İç padding'i kaldır */
}
#garage-status-container > div:last-child { /* Butonların olduğu div */
     flex-grow: 1; /* Kalan alanı kaplasın */
     justify-content: flex-end; /* Butonları sağa yasla */
}

.vehicle-detail-toggle-btn {
    transition: all 0.2s ease;
    border: none !important; /* Çerçeveyi kaldır */
    background: transparent !important; /* Arka planı kaldır */
    padding: 4px 8px !important; /* İç boşluğu azalt */
    font-size: 15px !important; /* Diğer metinlerle aynı */
    font-weight: 500 !important; /* Normal font */
    color: var(--muted) !important; /* Normalde soluk renk */
    text-shadow: none !important;
    flex: initial !important; /* Esnemesin */
    margin: 0 5px; /* Butonlar arası boşluk */
}

.vehicle-detail-toggle-btn:hover {
    color: white !important; /* Üzerine gelince beyaz */
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.7); /* Parlama */
    border-color: transparent !important; /* Hover'da çerçeve çıkmasın */
}

.vehicle-detail-toggle-btn[data-selected="true"] {
    background-color: transparent !important;
    border-color: transparent !important;
    color: var(--theme-color) !important; /* Seçiliyken tema rengi */
    font-weight: 700 !important; /* Seçiliyken kalın */
    text-shadow: none !important;
}
/* Seçili butonun hover efektini iptal et */
.vehicle-detail-toggle-btn[data-selected="true"]:hover {
     text-shadow: none !important;
}


/* Sağ Sütun - Textarea Font Boyutu */
#vehicle-detail-location,
#vehicle-detail-notes {
  font-size: 15px !important;
  padding-top: 0px !important;
  color: var(--muted) !important;
  resize: vertical !important;
}

/* Sağ Sütun - Notlar Başlığı (Hover kaldırıldı, boşluk ve font ayarı) */
#vehicle-detail-view div[style*="grid-template-columns: 1fr 1fr"] > div:last-child > div:last-child > div:first-child {
     padding: 0 !important;
     margin-bottom: 8px !important;
     font-size: 15px !important;
     font-weight: 600 !important;
     color: var(--text-color) !important;
     cursor: default !important;
}

/* Responsive */
@media (max-width: 768px) {
    #vehicle-detail-view > div > div:nth-child(2) { /* İki kolonlu grid */
        grid-template-columns: 1fr !important;
        gap: 20px !important; /* Mobil için dikey boşluk */
    }

     /* Sol ve Sağ Sütun İç Boşlukları */
    #vehicle-detail-view div[style*="grid-template-columns: 1fr"] > div > div {
         gap: 12px !important;
    }

    #vehicle-detail-plate {
        font-size: 24px !important;
    }

    #vehicle-detail-brand-model {
        font-size: 24px !important;
    }

    /* Mobil için "Galeride mi?" hizalaması */
    #garage-status-container {
        flex-direction: column; /* Alt alta */
        align-items: flex-start !important; /* Sola yasla */
        gap: 8px !important;
    }
     #garage-status-container > div:last-child {
         justify-content: flex-start; /* Butonları sola yasla */
