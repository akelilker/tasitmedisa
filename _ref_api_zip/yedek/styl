#vehicle-detail-view:not(.view-mode) #vehicle-detail-btn-edit {
    display: none;
}
/* ★ GÖREV 8: Butonları 1fr 1fr yap */
/* Düzenleme modunda GÜNCELLE butonunu göster (grid-column) */
#vehicle-detail-view:not(.view-mode) #vehicle-detail-btn-update {
    display: block;
    grid-column: 1 / span 1;
}
/* Düzenleme modunda TAMAM butonunu göster (grid-column) */
