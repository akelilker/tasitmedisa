    display: none;
}
/* ★ GÖREV 8: Butonları 1fr 1fr yap */
/* Görüntü modunda DÜZENLE butonunu göster (grid-column) */
#vehicle-detail-view.view-mode #vehicle-detail-btn-edit {
    display: block;
    grid-column: 1 / span 1; 
}
/* Görüntü modunda TAMAM butonunu göster (grid-column) */
#vehicle-detail-view.view-mode #vehicle-detail-btn-done {
    display: block;
    grid-column: 2 / span 1; /* 2 / span 2'den GÜNCELLENDİ */
}

/* ★ GÖREV 1 & 3: Pasif modda sola yaslama ve boşluk sıfırlama */
