@media (min-width: 1200px) {
  .wrap {
    max-width: 600px;
  }
}

#modal-veri .m-wrap.blurred { filter: blur(4px); transform: scale(0.98); transition: all 0.3s ease; }
.modal-blurred { filter: blur(4px) !important; transform: scale(0.98) !important; transition: all 0.3s ease !important; }

@keyframes width-pulse { 0% { width: 68%; opacity: 0.7; } 50% { width: 72%; opacity: 1; } 100% { width: 68%; opacity: 0.7; } }
@keyframes float-shadow { 0%, 100% { transform: translateY(-1px); } 50% { transform: translateY(1px); } }

.styled-radio-group { display: flex; gap: 20px; margin-bottom: 4px; padding: 4px 0; }
.styled-radio-group input[type="radio"] { display: none; }
.styled-radio-group label { flex: initial; padding: 2px; cursor: pointer; transition: all 0.2s ease; color: #bbb; font-size: 14px; font-weight: 600; background-color: transparent; border: none; }
.styled-radio-group label:hover { color: #fff; text-shadow: 0 0 12px rgba(255, 255, 255, 0.8); }
.styled-radio-group input[type="radio"]:checked + label { color: #fff; text-shadow: 0 0 12px rgba(255, 255, 255, 0.9), 0 0 25px rgba(255, 255, 255, 0.6); }

.input-with-adornment { position: relative; }
.input-with-adornment input { padding-right: 35px !important; }
.input-with-adornment::after { content: 'TL'; position: absolute; top: 50%; right: 12px; transform: translateY(-50%); color: var(--muted); opacity: 0.5; font-size: 14px; }
.input-error { border-color: var(--danger-red) !important; box-shadow: 0 0 0 2px rgba(255, 42, 42, 0.2) !important; }
#purchase-installments-wrap.row { grid-template-columns: 3fr 1fr; align-items: end; }

.toast { position: fixed; top: 15px; left: 50%; transform: translateX(-50%); padding: 10px 20px; border-radius: 8px; z-index: 9999; font-size: 14px; font-weight: 600; opacity: 0; animation: fadeInOut 2.5s ease-in-out forwards; width: 90%; max-width: 500px; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; background-color: rgba(45, 45, 45, 0.9); border: 2px solid #888; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5); color: #f0f0f0; text-shadow: 0 1px 1px rgba(0, 0, 0, 0.4); }
.toast.ok { color: var(--green); text-shadow: 0 1px 1px rgba(0, 0, 0, 0.4), 0 0 8px rgba(76, 250, 117, 0.5); }
.toast.err { color: var(--danger-red); text-shadow: 0 1px 1px rgba(0, 0, 0, 0.4), 0 0 8px rgba(255, 42, 42, 0.5); }
.toast.warn { color: var(--orange); text-shadow: 0 1px 1px rgba(0, 0, 0, 0.4), 0 0 8px rgba(255, 136, 68, 0.5); }
.toast.info { color: #add8e6; text-shadow: 0 1px 1px rgba(0, 0, 0, 0.4), 0 0 8px rgba(0, 80, 161, 0.5); }
@keyframes fadeInOut { 0%, 100% { opacity: 0; top: 0px; } 15%, 85% { opacity: 1; top: 15px; } }

.filter-date-group { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px; gap: 8px; }
