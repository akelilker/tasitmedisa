}

/* YENİ EKLENDİ (Tramer Buton Stili) */
.vehicle-yesno-btn {
    background: transparent;
    border: none;
    padding: 4px 8px;
    font-size: 15px;
    font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s ease;
}
.vehicle-yesno-btn:hover {
    color: white;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.7);
}

/* ★ GÖREV 2: Tramer Stilleri (Eski modal stillerinden alındı) */
.vehicle-yesno-btn.btn-no.active[data-field="tramer"] {
    color: #10b981;
    text-shadow: 0 0 10px #10b981, 
                 0 0 20px rgba(16, 185, 129, 0.6);
    animation: green-pulse 0.8s ease-in-out infinite;
}
.vehicle-yesno-btn.btn-yes.active[data-field="tramer"] {
    color: #ef4444;
    text-shadow: 0 0 10px #ef4444, 
                 0 0 20px rgba(239, 68, 68, 0.6);
    animation: red-pulse 0.8s ease-in-out infinite;
}
.vehicle-tramer-item {
     display: grid;
     grid-template-columns: 120px 1fr 20px;
     gap: 8px;
     align-items: center;
     padding: 8px;
     background: transparent;
     border-radius: 6px;
     border: none;
