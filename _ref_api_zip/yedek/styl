}

/* ====================================================================
   ARAÇ DETAY MODALI - TARİH ALANI DÜZELTMESİ (EKSİK STİLLER)
   ==================================================================== */

.vehicle-detail-date-field {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 2px !important;
  background: transparent !important;
  /* Hafif bir arka plan */
    border: 1px solid var(--br);
  border-radius: 8px;
  padding: 4px 0 !important;
  cursor: pointer;
  transition: background-color 0.2s ease, border-color 0.2s ease;
  border: none !important;
  color: var(--txt) !important;
  pointer-events: auto !important;
}

.vehicle-detail-date-field:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: #666;
}

.vehicle-detail-date-label {
    flex-grow: 1;
}

.vehicle-detail-date-label-text {
    font-size: 15px !important;
    color: var(--muted);
    margin-bottom: 2px !important;
    font-weight: 500;
}

.vehicle-detail-date-value {
    font-size: 15px !important;
    font-weight: 600;
    color: var(--text-color);
}

/* ★ GÖREV 5: Takvim simgesini küçült */
.vehicle-detail-calendar-icon {
  width: 15px !important;
  /* 24px'den 15px'e GÜNCELLENDİ */
    height: 15px;
  /* 24px'den 15px'e GÜNCELLENDİ */
    stroke: var(--muted);
  stroke-width: 2;
  fill: none;
  flex-shrink: 0 !important;
  margin-left: 0 !important;
  height: 15px !important;
  cursor: pointer !important;
} 

.vehicle-detail-date-input {
    /* Gizli input alanını sakla (ama tıklanabilir tut) */
    position: absolute !important;
    left: -9999px !important;
    opacity: 0 !important;
    pointer-events: auto !important;
}

/* DÜZENLEME MODUNDA: Tarih input'larını görünür yap */
#vehicle-detail-view:not(.view-mode) .vehicle-detail-date-input {
    position: static !important;
    left: 0 !important;
    opacity: 1 !important;
    width: 100%;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--br);
    border-radius: 8px;
    color: var(--txt);
    font-size: 15px;
    cursor: pointer;
}

/* DÜZENLEME MODUNDA: Date field ve takvim ikonunu gizle */
#vehicle-detail-view:not(.view-mode) .vehicle-detail-date-field {
    display: none !important;
}

/* ====================================================================
   ARAÇ DETAY MODALI - YENİ DÜZENLEME MODU STİLLERİ (EKLENDİ)
   ==================================================================== */

/* ★ GÖREV 8: Butonların temel rengini parlat */
.vehicle-detail-btn {
  background: transparent !important;
  border: none !important;
  color: var(--txt) !important;
  /* #ccc'den #f0f0f0'a GÜNCELLENDİ */
    font-weight: 600;
  padding: 10px 14px;
  cursor: pointer;
  transition: all 0.3s ease;
  border-radius: 8px;
  font-size: 17px !important;
  /* Fontu büyüt */
    text-shadow: none;
  font-family: inherit;
  line-height: 1.2;
  /* Düğme yüksekliğini ayarla */
    min-height: 38px;
  font-weight: 600 !important;
}
.vehicle-detail-btn:hover {
    color: #fff;
    transform: scale(1.05);
}

/* Buton Parlama Efektleri */
#vehicle-detail-btn-update.btn:hover {
    /* .btn'den gelen !important'ı ezmek için .btn kullandık */
    color: var(--green) !important;
    text-shadow: 0 0 15px var(--green), 0 0 25px rgba(76, 250, 117, 0.7);
}
#vehicle-detail-btn-edit.btn.sec:hover {
    color: var(--orange) !important;
    text-shadow: 0 0 15px var(--orange), 0 0 25px rgba(255, 136, 68, 0.7);
}
#vehicle-detail-btn-done.btn.sec:hover {
    color: #fff !important;
    text-shadow: 0 0 25px rgba(255, 255, 255, 0.9), 0 0 45px rgba(255, 255, 255, 0.7);
}


/* --- GÖRÜNTÜ MODU (.view-mode) --- */
/* Görüntü modunda GÜNCELLE butonunu gizle */
