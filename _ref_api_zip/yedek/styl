  margin-bottom: 0px !important;
  color: #fff !important;
  font-weight: 600 !important;
}
#vehicle-detail-view.view-mode .vehicle-detail-textarea {
    background: transparent;
    border-color: transparent;
    padding-left: 10px;
    padding-right: 10px;
