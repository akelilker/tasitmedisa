/* ====================================================================
7. RESPONSIVE TASARIM - KOMPLE YENİ HALİ
==================================================================== */
@media (max-width: 640px) {
  html, body {
    overflow: hidden;
    height: 100%;
  }

  body {
    display: flex;
    flex-direction: column;
    height: 100vh;
    position: relative;
  }

  /* Modal açıkken ana çerçeveyi gizle */
  body:has(.modal.on)::before {
    display: none !important;
  }

  /* --- Madde 4: Ana Çerçeve Kalınlığı --- */
  body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 40px;
    border-radius: 24px;
    border-width: 2px;
    border-style: solid;
    border-image-source: linear-gradient(90deg, rgba(180, 180, 180, 0.5) 0%, rgba(230, 230, 230, 0.8) 25%, rgba(255, 255, 255, 1) 50%, rgba(230, 230, 230, 0.8) 75%, rgba(180, 180, 180, 0.5) 100%);
    border-image-slice: 1;
    z-index: 9999;
    pointer-events: none;
  }

  .wrap {
    flex: 1;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    min-height: 0;
    margin: 0;
    padding: calc(20px + env(safe-area-inset-top, 0px)) 16px 60px 16px;
    border-radius: 0;
    border: none;
    box-shadow: none;
    background-image: none;
    position: relative;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  body:has(.modal.on) .wrap {
      padding-bottom: 0 !important;
  }

  .wrap::-webkit-scrollbar {
    display: none;
  }

  .status-bar {
    position: fixed !important;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 200;
    flex-shrink: 0;
    padding-bottom: env(safe-area-inset-bottom);
    border-top: none;
    box-shadow: none;
  }

  .status-bar-content {
    padding: 6px 16px;
  }

  .row {
    grid-template-columns: 1fr;
  }

  .hero {
    padding: 20px 16px;
    margin-bottom: 8px;
  }

  .hero h1 {
    font-size: 24px !important;
    padding-bottom: 12px !important;
    background: linear-gradient(180deg,
        hsl(0, 0%, 100%) 0%,
        hsl(0, 0%, 95%) 30%,
        hsl(0, 0%, 75%) 50%,
        hsl(0, 0%, 85%) 70%,
        hsl(0, 0%, 100%) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: none;
    filter: brightness(1.3) contrast(2);
  }

  .hero-icons {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    padding: 8px 0 4px 0;
    align-items: center;
    position: relative;
  }

  .hero-icon {
    width: 20px;
    height: 20px;
    color: #aaaaaa;
  }
  .hero-icon:hover, .hero-icon:focus-visible {
    color: #cccccc !important;
    filter: drop-shadow(0 0 8px rgba(204, 204, 204, 0.6)) !important;
  }
  .hero-icon.alert-warning { color: var(--orange) !important; filter: drop-shadow(0 0 8px var(--orange)); animation: pulse-orange 1.5s infinite, float-shadow 3s infinite ease-in-out; }
  .hero-icon.alert-danger { color: var(--danger-red) !important; }
  .hero-icon.alert-warning:hover { filter: drop-shadow(0 0 12px var(--orange)) drop-shadow(0 0 25px rgba(255, 136, 68, 0.6)); }
  .hero-icon.alert-danger:hover {
      color: var(--danger-red) !important;
  }

  .grid-4 {
    margin: 8px 0;
  }

  .menu-btn {
    border: 1px solid rgba(255, 255, 255, 0.35);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.08), inset 0 -1px 1px rgba(0, 0, 0, 0.3), 0 4px 12px rgba(0,0,0,0.5);
  }

  .menu-btn .ttl {
    font-size: 14px;
    letter-spacing: 2px;
  }

  .cat-group-row {
    flex-wrap: wrap;
  }

  .stats {
    flex-direction: column;
    gap: 8px;
  }

  .stat {
    flex: 1;
    padding: 12px 4px !important;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--br);
    border-radius: 10px;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.3);
  }

  .modal {
    padding: 0;
    align-items: stretch;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10000;
    background: var(--bg);
  }

  .modal.on {
      display: flex;
      opacity: 1;
  }

 .modal .m-wrap {
  width: 100%;
  height: auto;
  border-radius: 16px !important;
  border: none !important;
  margin: auto;
  background: var(--bg);
  padding: calc(env(safe-area-inset-top, 0px) + 16px) 0 calc(env(safe-area-inset-bottom, 0px) + 16px) 0 !important;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

  /* YENİ YÖNTEM: Parlama efekti için ::before kullan (Yumuşak + Tam Ekran) */
  .modal.on .m-wrap::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    border-radius: 0;
    pointer-events: none;
    box-shadow:
        0 0 20px 10px rgba(255, 255, 255, 0.2),
        0 0 40px 15px rgba(255, 255, 255, 0.1);
    z-index: -1;
  }

  .modal .modal-header {
      flex-shrink: 0;
      padding-bottom: 8px;
      margin-bottom: 15px;
      padding-top: 0;
      padding-left: 16px;
      padding-right: 16px;
  }
  .modal .m-content {
      padding: 0 16px 10px 16px;
      scrollbar-width: none;
     -ms-overflow-style: none;
  }
   .modal .m-content::-webkit-scrollbar { display: none; }

  input::placeholder,
  textarea::placeholder {
    color: rgba(235, 255, 245, 0.6);
    opacity: 1;
  }

  .stats.stats-5col {
    grid-template-columns: repeat(5, 1fr) !important;
    gap: 3px !important;
    margin-left: 0;
    margin-right: 0;
  }

   .stats.stats-5col .stat:last-child {
      grid-column: auto !important;
   }

  .sv {
    font-size: clamp(10px, 2.6vw, 12px) !important;
    letter-spacing: -0.8px;
    height: 15px !important;
    line-height: 15px !important;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    color: var(--green) !important;
    text-shadow: none !important;
  }
  .sv.neg {
      color: var(--danger-red) !important;
  }

  .sl {
      font-size: 8px !important;
      height: 11px !important;
      line-height: 11px !important;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: #cccccc !important;
      text-shadow: none !important;
  }


 #account-selector-wrap,
