     text-shadow: 0 0 5px rgba(255, 170, 170, 0.5);
  }

  #modal-cari .m-wrap {
    height: auto;
    max-height: 85vh;
  }
  #modal-cari .m-content {
      padding-bottom: 0;
      display: flex;
      flex-direction: column;
      padding-left: 0;
