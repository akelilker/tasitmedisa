      grid-template-columns: minmax(180px, 1fr) minmax(180px, 1fr) 80px 40px;
      align-items: center;
      gap: 10px;
      padding-bottom: 0;
      border-bottom: none;
      margin-bottom: 0;
  }
  #joint-partners-inputs .partner-row {
      display: grid;
      grid-template-columns: minmax(180px, 1fr) minmax(180px, 1fr) 80px 40px;
      align-items: start;
      gap: 10px;
      padding-bottom: 0;
      border-bottom: none;
      margin-bottom: 0;
      position: relative;
  }

  #joint-partners-inputs .partner-row > div:nth-child(1),
  #joint-partners-inputs .partner-row > div:nth-child(2) {
      grid-column: auto;
      position: static;
      text-align: left;
  }

  #joint-partners-inputs .partner-row > div:nth-child(3),
  #joint-partners-inputs .partner-row > div:nth-child(4) {
      position: static;
  }
  #joint-partners-inputs .company-row > div:nth-child(2) { }

   #joint-partners-inputs .partner-row > div:nth-child(4) {
       position: static;
   }
   #joint-partners-inputs .remove-partner-btn {
       padding: 0 !important;
       font-size: 20px !important;
       line-height: 1;
       transform: translateY(0);
   }

    /* Şirket Payı ve Ödenen TL hizalaması (Mobil) */
    #joint-partners-inputs .company-row {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 6px;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--br);
        margin-bottom: 0px;
    }
    #joint-partners-inputs .company-row > div {
        width: 100%;
        text-align: left;
        grid-column: auto;
        position: static;
        align-self: auto;
        padding-bottom: 0;
        height: auto;
    }

  /* MASAÜSTÜ ORTAKLI ALIM - Yüzde ve Buton Dikey Hizalama */
