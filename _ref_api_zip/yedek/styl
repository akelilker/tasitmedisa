}
/* ★ Bitiş: Tramer Stilleri */

/* YENİ EKLENDİ (Tramer Ekle Buton Stili) */
.vehicle-add-part-btn {
    background: transparent;
    border: none;
    color: var(--theme-color);
    font-size: 15px;
    font-weight: 600;
    padding: 0;
    margin-top: 8px;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s ease;
}
.vehicle-add-part-btn:hover {
    color: #fff;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.7);
}
.vehicle-add-part-btn .icon {
    display: inline-block;
    font-weight: bold;
    margin-right: 4px;
}


/* ===== PARLAMALI BUTON EFEKTLERİ ===== */

.btn-edit-mode {
    background: none;
    border: none;
    color: var(--text);
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-block;
    position: relative;
    overflow: hidden;
}

/* Düzeltme Butonu - Sarı Parlamalar */
.btn-edit-yellow:hover {
    color: #FFD700;
    text-shadow: 0 0 10px #FFD700, 0 0 20px rgba(255, 215, 0, 0.5);
    animation: glow-yellow 0.6s ease-in-out infinite;
}

@keyframes glow-yellow {
    0%, 100% {
        text-shadow: 0 0 10px #FFD700, 0 0 20px rgba(255, 215, 0, 0.5);
    }
    50% {
        text-shadow: 0 0 20px #FFD700, 0 0 40px rgba(255, 215, 0, 0.8), 0 0 60px rgba(255, 215, 0, 0.4);
    }
}

/* Güncelle Butonu - Yeşil Parlamalar */
.btn-edit-green:hover {
    color: var(--theme-color);
    text-shadow: 0 0 10px var(--theme-color), 0 0 20px rgba(76, 175, 80, 0.5);
    animation: glow-green 0.6s ease-in-out infinite;
}

@keyframes glow-green {
    0%, 100% {
        text-shadow: 0 0 10px var(--theme-color), 0 0 20px rgba(76, 175, 80, 0.5);
    }
    50% {
        text-shadow: 0 0 20px var(--theme-color), 0 0 40px rgba(76, 175, 80, 0.8), 0 0 60px rgba(76, 175, 80, 0.4);
    }
}

/* Tamam Butonu - Beyaz Parlamalar */
.btn-edit-white:hover {
    color: #FFFFFF;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.8), 0 0 20px rgba(255, 255, 255, 0.5);
    animation: glow-white 0.6s ease-in-out infinite;
}

@keyframes glow-white {
    0%, 100% {
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.8), 0 0 20px rgba(255, 255, 255, 0.5);
    }
    50% {
        text-shadow: 0 0 20px rgba(255, 255, 255, 1), 0 0 40px rgba(255, 255, 255, 0.8), 0 0 60px rgba(255, 255, 255, 0.4);
    }
}

/* Kırmızı Parlamalar */
.btn-edit-red:hover {
    color: var(--danger);
    text-shadow: 0 0 10px var(--danger), 0 0 20px rgba(244, 67, 54, 0.5);
    animation: glow-red 0.6s ease-in-out infinite;
}

@keyframes glow-red {
    0%, 100% {
        text-shadow: 0 0 10px var(--danger), 0 0 20px rgba(244, 67, 54, 0.5);
    }
    50% {
        text-shadow: 0 0 20px var(--danger), 0 0 40px rgba(244, 67, 54, 0.8), 0 0 60px rgba(244, 67, 54, 0.4);
    }
}

/* ===== ARAÇ DETAY METINLER (Pasif Mod) ===== */

.vehicle-detail-text {
    background: none;
    border: none;
    padding: 6px 0;
    color: var(--text);
    font-size: 14px;
    margin: 8px 0;
    line-height: 1.6;
}

.vehicle-detail-label {
    color: var(--muted);
    font-size: 12px;
    text-transform: uppercase;
    margin-bottom: 4px;
    display: block;
}

/* ===== MODAL SCROLL ===== */

.m-content {
    max-height: calc(90vh - 180px);
    overflow-y: auto;
}

.m-content::-webkit-scrollbar {
    width: 6px;
}

.m-content::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 3px;
}

.m-content::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 3px;
}

.m-content::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.3);
}

/* ===== BUTON TOGGLE STILERI ===== */

.button-toggle {
    display: flex;
    gap: 8px;
    margin: 12px 0;
}

.button-toggle button {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid var(--border-color);
    background: var(--card-bg);
    color: var(--text);
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 13px;
    font-weight: 500;
}

.button-toggle button:hover {
    border-color: var(--theme-color);
}

.button-toggle button.active {
    background: var(--theme-color);
    color: #000;
    border-color: var(--theme-color);
}

/* ====================================================================
   TAŞIT DETAY EKRANI - TEMİZLİK OPERASYONU (v3)
   Aşağıdaki kodlar, index.html'den taşınan ve temizlenen stillerdir.
   ==================================================================== */

/* DÜZELTME: Plaka/Modeli ortalamak için eklendi */
.vehicle-detail-header {
    text-align: center;
}

/* Ana Grid Yapısı (index.html'den taşındı) */
.vehicle-detail-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 20px;
    margin-bottom: 8px;
}
@media (max-width: 640px) {
    .vehicle-detail-content {
        grid-template-columns: 1fr;
        gap: 0; /* Mobilde satırlar arası boşluk yok */
    }
}

/* Sütunlar (index.html'den taşındı) */
.vehicle-detail-info-section, 
.vehicle-detail-right-section {
    display: flex;
    flex-direction: column;
}

.vehicle-detail-info-section {
    gap: 6px; /* DÜZELTME: 4px -> 6px olarak güncellendi */
}

.vehicle-detail-right-section {
    gap: 0;
}

/* Her bir bilgi satırı (Model Yılı + 2019) */
.vehicle-detail-info-item {
    /* DÜZELTME: Yan yana hizalama */
    display: flex;
    align-items: center; /* Dikeyde ortala */
    gap: 8px;
    padding-top: 0;
    /* DÜZELTME: min-height: 20px SİLİNDİ */
}

/* İstisna: Alt alta olması gerekenler (Boyalı ve Notlar) */
.vehicle-detail-info-item.item-stacked {
    display: block; /* Flex'i iptal et, alt alta gelsinler */
}
.vehicle-detail-info-item.item-stacked .vehicle-detail-info-label {
    margin-bottom: 2px;
}

#vehicle-detail-location-section {
    margin-bottom: -8px !important;
}

.vehicle-detail-location-label {
    display: none !important;
}

/* Başlıklar (Model Yılı, Km, vb.) */
.vehicle-detail-info-label {
    font-size: 15px !important;
    color: var(--muted);
    margin-bottom: 0px !important; /* Düzeltme: 0px */
    font-weight: 500;
    flex-shrink: 0; /* Başlıkların daralmasını engelle */
}
/* Görüntü (Pasif) Mod Başlıkları */
#vehicle-detail-view.view-mode .vehicle-detail-info-label {
    color: #fff !important;
    font-weight: 600 !important;
}

/* Değer Alanları (Input, Textarea, Pasif Metin) */
.vehicle-detail-textarea,
#tramer-passive-content,
#vehicle-detail-garage-passive-text {
    font-size: 15px !important;
    padding-top: 0px !important; /* Düzeltme: 0px */
    padding-bottom: 0px !important; /* Düzeltme: 0px */
    padding-left: 0px !important; /* Düzeltme: Sola yasla */
    padding-right: 0px;
    text-align: left; /* Düzeltme: Sola yasla */
    color: var(--muted);
    border: none;
    min-height: 0; /* Textarea'nın varsayılan yüksekliğini sıfırla */
    height: auto; /* YENİ EKLENDİ - İçeriğe göre yüksekliği ayarla */
    resize: none !important; /* YENİ EKLENDİ - O eski resize kuralını ez */
}
 
/* Düzenleme Modundaki Alanlar */
#vehicle-detail-view:not(.view-mode) .vehicle-detail-textarea {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--br);
    padding: 8px 10px; /* Düzenleme modunda padding ver */
    color: var(--text-color);
    border-radius: 4px;
}
#vehicle-detail-view:not(.view-mode) #vehicle-detail-painted-parts-input {
    min-height: 80px;
}
#vehicle-detail-view:not(.view-mode) #vehicle-detail-notes {
    min-height: 100px;
}

/* Pasif (Görüntü) Modundaki Alanlar */
#vehicle-detail-view.view-mode .vehicle-detail-textarea,
#vehicle-detail-view.view-mode #tramer-passive-content,
#vehicle-detail-view.view-mode #vehicle-detail-garage-passive-text {
    appearance: none !important;
    -webkit-appearance: none !important;
    background: transparent !important;
    border: none !important;
    color: var(--muted) !important;
    pointer-events: none !important;
    resize: none !important;
}

/* Tarih Alanları */
.vehicle-detail-date-field {
    background: transparent !important;
    border: none !important;
    padding: 0px !important; /* Düzeltme: 0px dikey boşluk */
    display: flex;
    align-items: center;
    cursor: pointer;
    gap: 8px; /* Tarih ve Simge arası boşluk */
}
.vehicle-detail-date-value {
    font-size: 15px !important;
    font-weight: 600;
    color: var(--muted); /* DÜZELTME: Pasif modda soluk renk */
}
.vehicle-detail-calendar-icon {
    width: 15px !important;
    height: 15px !important;
    stroke: var(--muted);
}
.vehicle-detail-date-input {
    position: absolute !important;
    left: -9999px !important;
    opacity: 0 !important;
}
/* Pasif (Görüntü) Modu Tarih Alanları */
#vehicle-detail-view.view-mode .vehicle-detail-date-field {
    cursor: default;
    pointer-events: none;
}
#vehicle-detail-view.view-mode .vehicle-detail-calendar-icon {
    display: none; /* DÜZELTME: Pasif modda takvimi gizle */
}

/* Galeri Butonları */
.vehicle-detail-garage-section {
    display: flex;
    align-items: center;
    gap: 15px;
    flex-wrap: wrap;
}
.vehicle-detail-garage-label {
    margin-bottom: 0 !important;
    flex-shrink: 0;
}
.vehicle-detail-garage-buttons {
    flex-grow: 1;
    display: flex;
    justify-content: flex-end;
}
.vehicle-detail-garage-btn {
    transition: all 0.2s ease;
    border: none; /* DÜZELTME: Kutu kaldırıldı */
    background: transparent;
    padding: 4px 8px;
    font-size: 15px;
    font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    margin-left: 5px;
    border-radius: 4px;
}
.vehicle-detail-garage-btn[data-selected="true"] {
    /* DÜZELTME: Arka plan rengi kaldırıldı, sadece metin rengi */
    color: var(--theme-color) !important;
    font-weight: 700;
}
@media (max-width: 640px) {
    .vehicle-detail-garage-section {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
    }
    .vehicle-detail-garage-buttons {
        justify-content: flex-start;
        width: 100%;
    }
}

/* Alt Butonlar */
.vehicle-detail-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    margin-top: 0;
    padding-top: 0;
}
.vehicle-detail-btn {
    width: 100%;
}
 

/* Plaka/Model Ortalaması */
.vehicle-detail-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 12px;
    margin-top: -12px;
}