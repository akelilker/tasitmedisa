  /* Ortaklı Alım Mobil Görünümü (Tek Sütun) */
  #joint-partners-inputs .partner-row,
  #joint-partners-inputs .company-row {
      display: flex;
      flex-direction: column;
      gap: 8px;
      position: relative;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--br);
      margin-bottom: 0px;
  }
  #joint-partners-inputs .partner-row:last-child,
  #joint-partners-inputs .company-row {
      border-bottom: none;
