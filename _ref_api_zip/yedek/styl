    color: #ffffff;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.5);
  }
  .settings-dropdown button.danger {
    color: #ffaaaa;
  }
  .settings-dropdown button.danger:hover {
     background: var(--danger-red-subtle);
     border-color: var(--danger-red);
